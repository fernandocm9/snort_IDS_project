alert icmp any any -> any any (msg:"ICMP Ping Detected"; sid:1000001; rev:1;)
alert tcp any any -> any any (flags:S; msg:"Possible SYN Scan"; detection_filter:track by_src, count 20, seconds 10; sid:1000002; rev:1;)
alert tcp any any -> any 22 (msg:"Possible SSH Brute Force"; detection_filter:track by_src, count 5, seconds 60; sid:1000003; rev:1;)
alert icmp any any -> any any (msg:"ICMP Flood Detected"; detection_filter:track by_src, count 10, seconds 5; sid:1000004; rev:1;)
