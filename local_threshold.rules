alert tcp any any -> any any (flags:S; msg:"Possible SYN Scan"; detection_filter:track by_src, count 100, seconds 10; sid:2000002; rev:2;)
alert tcp any any -> any 22 (msg:"Possible SSH Brute Force"; detection_filter:track by_src, count 20, seconds 60; sid:2000003; rev:2;)
alert icmp any any -> any any (itype:8; msg:"ICMP Flood Detected"; detection_filter:track by_src, count 50, seconds 5; sid:2000004; rev:2;)
